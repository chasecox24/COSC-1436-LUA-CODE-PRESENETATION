DataService:getIndexChangedSignal(DataPaths.Equipped / Types.ItemType.Armor):Connect(function(armorType: Types.ArmorSubType, UID: string?, oldUID: string?)
	setEquippedUniqueItem(ArmorContainer, armorType, UID, oldUID)	
end)

DataService:getIndexChangedSignal(DataPaths.Stackables):Connect(function(itemName, currentValue: number?)
	local slotFrame = BagContainer:FindFirstChild(itemName) :: typeof(InventorySlot)
	
	if slotFrame == nil then
		createStackableBagSlot(itemName, currentValue)
	else
		if currentValue ~= nil then
			slotFrame.Container.Quantity.QuantityLabel.Text = "x"..currentValue
		else
			slotFrame:Destroy()

			createEmptyBagSlot()
		end
	end
end)

DataService:getIndexChangedSignal(DataPaths.UniqueItems):Connect(function(UID: string, UniqueItem: DataTemplate.UniqueItem?)
	-- get the slot
	local slotFrame = BagContainer:FindFirstChild(UID) :: typeof(InventorySlot)
	-- check if nil
	if slotFrame == nil then
		createUniqueBagSlot(UID)
	else
		if UniqueItem == nil then
			slotFrame:Destroy()
			
			createEmptyBagSlot()
		else
			error("what the flip")
		end
	end
end)

DataService:getIndexChangedSignal(DataPaths.Equipped / Types.ItemType.Tools):Connect(function(toolType: string, UID: string, oldUID: string?)
	setEquippedUniqueItem(ToolContainer, toolType, UID, oldUID)
end)

-- create the empty slots
for i = 1, BagCapacity do
	createEmptyBagSlot()
end

-- load the stackables
for itemName: string, amount: number in DataService:get(DataPaths.Stackables) do
	createStackableBagSlot(itemName, amount)
end

-- load the unique items
for UID: string, UniqueItem: DataTemplate.UniqueItem in DataService:get(DataPaths.UniqueItems) do
	createUniqueBagSlot(UniqueItem.Id, UniqueItem.UID)
end
