game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, false)

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterGui = game:GetService("StarterGui")

local DataService = require(ReplicatedStorage:WaitForChild("Data"):WaitForChild("DataService")).client
local DataPaths = require(ReplicatedStorage:WaitForChild("Data"):WaitForChild("DataPaths"))
local DataTemplate = require(ReplicatedStorage:WaitForChild("Data"):WaitForChild("DataTemplate"))

local Types = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Types"))

local InventoryEquipRemote = ReplicatedStorage:WaitForChild("Remote"):WaitForChild("InventoryEquip")

local InventoryAction = script.Parent.Parent:WaitForChild("Inputs"):WaitForChild("GameContext"):WaitForChild("Inventory")
local BagCapacity = 40
local BagItemCount = 0

local InventoryGUI = script.Parent
local ArmorContainer = InventoryGUI:FindFirstChild("ArmorContainer", true)
local ToolContainer = InventoryGUI:FindFirstChild("ToolContainer", true)
local BagContainer = InventoryGUI:FindFirstChild("BagContainer", true)
local InventorySlot = ReplicatedStorage:WaitForChild("Assets"):WaitForChild("InventoryItemSlot")
local InventoryEmptySlot = ReplicatedStorage:WaitForChild("Assets"):WaitForChild("InventoryEmptySlot")

DataService:waitForData()

InventoryAction.Pressed:Connect(function()
	InventoryGUI.Enabled = not InventoryGUI.Enabled --flip flops
end)

local function removeEmptyBagSlot()
	local destroyed = BagContainer:FindFirstChild("Empty")
	
	if destroyed ~= nil then
		destroyed:Destroy()
	end
end

local function createEmptyBagSlot()
	local slotFrame = InventoryEmptySlot:Clone()
	slotFrame.Parent = BagContainer
	slotFrame.Name = "Empty"
	slotFrame.LayoutOrder = 1
end

local function createStackableBagSlot(itemName: string, amount: number)
	local slotFrame = InventorySlot:Clone()
	slotFrame.Parent = BagContainer
	slotFrame.Name = itemName
	slotFrame.LayoutOrder = -1

	local container = slotFrame.Container
	container.NameLabel.Text = itemName
	container.Quantity.QuantityLabel.Text = "x"..amount
	
	BagItemCount += 1

	removeEmptyBagSlot()
end

local function createUniqueBagSlot(UID: string)
	local uniqueItem: DataTemplate.UniqueItem = DataService:get(DataPaths.UniqueItems / UID)
	
	local slotFrame = InventorySlot:Clone()
	slotFrame.Parent = BagContainer
	slotFrame.Name = UID
	slotFrame.LayoutOrder = -1

	local container = slotFrame.Container
	container.NameLabel.Text = uniqueItem.Id
	
	container.Quantity.Visible = false

	BagItemCount += 1
	
	removeEmptyBagSlot()
	
	container.Activated:Connect(function()
		InventoryEquipRemote:FireServer(UID)
	end)
end

local function setEquippedUniqueItem(parentContainer: Frame, subType: string, UID: string?, oldUID: string?)
	local subTypeContainer = assert(parentContainer:FindFirstChild(subType))
	local uniqueItem: DataTemplate.UniqueItem = DataService:get(DataPaths.UniqueItems / UID)
	
	if oldUID ~= nil then
		local oldSlotFrame = subTypeContainer:FindFirstChild(oldUID)

		if oldSlotFrame ~= nil then
			oldSlotFrame:Destroy()
		end

		createUniqueBagSlot(oldUID)
	end
	
	if UID ~= nil then
		local slotFrame = InventorySlot:Clone()
		slotFrame.Parent = subTypeContainer
		slotFrame.Name = UID
		
		local container = slotFrame.Container
		container.NameLabel.Text = uniqueItem.Id

		container.Quantity.Visible = false
		
		container.Activated:Connect(function()
			InventoryEquipRemote:FireServer(UID)
		end)
		
		local bagSlotFrame = BagContainer:FindFirstChild(UID)

		if bagSlotFrame ~= nil then
			bagSlotFrame:Destroy()
			
			createEmptyBagSlot()
		end
	end
end

local function setToolSlot(toolType: string, UID: string, oldUID: string?)
	local toolTypeContainer = assert(ToolContainer:FindFirstChild(toolType))
	local uniqueItem: DataTemplate.UniqueItem = DataService:get(DataPaths.UniqueItems / UID)
	
	-- put old tool back inside bag
	if oldUID ~= nil then
		-- remove old tool
		local oldSlotFrame = toolTypeContainer:FindFirstChild(oldUID)

		if oldSlotFrame ~= nil then
			oldSlotFrame:Destroy()
		end
		
		createUniqueBagSlot(oldUID)
	end

	-- create new tool inside equippedTool
	local slotFrame = InventorySlot:Clone()
	slotFrame.Parent = toolTypeContainer
	slotFrame.Name = UID

	local container = slotFrame.Container
	container.NameLabel.Text = uniqueItem.Id
	
	container.Quantity.Visible = false
end

