	DataService:waitForData(Player)

	-- check if ReceivedStarterPack is false
	if DataService:get(Player, DataPaths.ReceivedStarterPack) == false then
		local items = {
			{Id = "Bronze Pickaxe", UID = HttpService:GenerateGUID(false), Bonuses = {}},
			{Id = "Bronze Axe", UID = HttpService:GenerateGUID(false), Bonuses = {}},
			{Id = "Bronze Sword", UID = HttpService:GenerateGUID(false), Bonuses = {}},
			{Id = "Iron Pickaxe", UID = HttpService:GenerateGUID(false), Bonuses = {}},
			{Id = "Iron Axe", UID = HttpService:GenerateGUID(false), Bonuses = {}},
			{Id = "Iron Sword", UID = HttpService:GenerateGUID(false), Bonuses = {}},
			{Id = "Iron Helmet", UID = HttpService:GenerateGUID(false), Bonuses = {}};
			{Id = "Iron Chestplate", UID = HttpService:GenerateGUID(false), Bonuses = {}};
