end)

InventoryEquipRemote.OnServerEvent:Connect(function(player: Player, UID: string | unknown)
	local character = player.Character :: Character

	if not character then return end
	
	if type(UID) ~= "string" then return end
	
	local uniqueItem: DataTemplate.UniqueItem? = DataService:get(player, DataPaths.UniqueItems / UID)
	
	if uniqueItem == nil then return end

	local itemConfig = ItemConfig[uniqueItem.Id]
	
	local equippedItemPath = DataPaths.Equipped / itemConfig.type / itemConfig.subType
	local currentlyEquippedItemUID: string? = DataService:get(player, equippedItemPath)

	if itemConfig.type == Types.ItemType.Armor then
		if currentlyEquippedItemUID == nil or currentlyEquippedItemUID ~= uniqueItem.UID then
			DataService:set(player, equippedItemPath, uniqueItem.UID) -- clicking armor piece and equpping it
			
			-- attach armor model
			local armorModel = itemConfig.instance:Clone() :: Model
			armorModel.Parent = character:FindFirstChild("Armor") :: Folder
			armorModel.Name = itemConfig.subType
			
			local weld = Instance.new("Weld")
			weld.Parent = armorModel
			weld.Part0 = character:FindFirstChild(itemConfig.subType) :: Part 
			weld.Part1 = armorModel.PrimaryPart
			
			setAccessoriesByArmorSubtype(player, itemConfig.subType :: Types.ArmorSubType, false)
		else
			-- Clicking armor piece when you have it already equipped
			
			DataService:set(player, equippedItemPath, nil) -- Unequip it
			
			local armorModel = character.Armor:FindFirstChild(itemConfig.subType) :: Model
			armorModel:Destroy()
			
			setAccessoriesByArmorSubtype(player, itemConfig.subType :: Types.ArmorSubType, true)
		end
	elseif itemConfig.type == Types.ItemType.Tools then
		if currentlyEquippedItemUID == nil or currentlyEquippedItemUID ~= uniqueItem.UID then
			DataService:set(player, DataPaths.Equipped / itemConfig.type / itemConfig.subType, uniqueItem.UID)
		end
	end
end)
