--!strict

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

local DataService = require(ReplicatedStorage.Data.DataService).server
local DataTemplate = require(ReplicatedStorage.Data.DataTemplate)
local DataPaths = require(ReplicatedStorage.Data.DataPaths)

local Types = require(ReplicatedStorage.Modules.Types)

local ItemConfig = require(ReplicatedStorage.Configs.ItemConfig)

local InventoryEquipRemote = ReplicatedStorage.Remote.InventoryEquip

type Character = Model & {
	Armor: Folder
} -- what is this is

local ArmorRemovalMap: {[Types.ArmorSubType]: {Enum.AccessoryType} } = {
	Head = {
		Enum.AccessoryType.Hat,
		Enum.AccessoryType.Hair,
		Enum.AccessoryType.Face,
		Enum.AccessoryType.Eyebrow,
		Enum.AccessoryType.Eyelash
	},

	Torso = {
		Enum.AccessoryType.Shirt,
		Enum.AccessoryType.Jacket,
		Enum.AccessoryType.Sweater,
		Enum.AccessoryType.TShirt,
		Enum.AccessoryType.Front,
		Enum.AccessoryType.Back
	},

	["Left Arm"] = {
		Enum.AccessoryType.Shoulder
	},

	["Right Arm"] = {
		Enum.AccessoryType.Shoulder
	},

	["Left Leg"] = {
		Enum.AccessoryType.Pants,
		Enum.AccessoryType.Shorts,
		Enum.AccessoryType.LeftShoe,
		Enum.AccessoryType.DressSkirt,
		Enum.AccessoryType.Waist
	},

	["Right Leg"] = {
		Enum.AccessoryType.Pants,
		Enum.AccessoryType.Shorts,
		Enum.AccessoryType.RightShoe,
		Enum.AccessoryType.DressSkirt,
		Enum.AccessoryType.Waist
	}
}

local function setAccessoriesByArmorSubtype(player : Player, armorType: Types.ArmorSubType, visible: boolean)
	local character = player.Character
	if character == nil then return end
	
	local accessoryTypesToToggle = ArmorRemovalMap[armorType]

	for i, child in character:GetChildren() do
		if child:IsA("Accessory") and table.find(accessoryTypesToToggle, child.AccessoryType) then
			local accessoryHandle = child:FindFirstChild("Handle") :: BasePart
			
			if visible == true then
				accessoryHandle.Transparency = 0
			else
				accessoryHandle.Transparency = 1
			end
		end
	end
end

